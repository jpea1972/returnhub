# ─────────────────────────────────────────────────────────
# ReturnHub Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to Git — it contains your API token
# ─────────────────────────────────────────────────────────

# Return Rabbit API Token
# Get this from: Return Rabbit → Settings → API → Generate Token
RR_TOKEN=paste_your_return_rabbit_token_here

# Return Rabbit API base URL (don't change unless RR tells you to)
RR_BASE_URL=https://api.returnrabbit.app

# Port the server runs on (Railway/Render set this automatically)
PORT=3000

# Allowed origin for CORS (your domain in production, * for open)
# Example: ALLOWED_ORIGIN=https://returns.paragonfitwear.com
ALLOWED_ORIGIN=*
